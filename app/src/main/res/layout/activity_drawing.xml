<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Top App Bar with Back Button -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        app:title=""
        android:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Back Button -->
            <ImageView
                android:id="@+id/buttonBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Back"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                 />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Drawing Canvas"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginStart="12dp" />

            <TextView
                android:id="@+id/textViewToolMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pen"
                android:textSize="13sp"
                android:textColor="@color/gray_500"
                android:background="@drawable/bg_tool_mode"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginEnd="12dp" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/buttonResetView"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_reset"
                android:backgroundTint="#000000"
                app:tint="@color/white"
                app:elevation="0dp"
                app:borderWidth="0dp" />

        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gray_200" />

    <!-- Drawing Area -->
    <com.example.zodiaccalculator.screen.drawing.DrawingView
        android:id="@+id/drawingView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/white" />

    <!-- Tool Bar (Sleek, Rounded, Modern) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="8dp">

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gray_200" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPen"

                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:textAllCaps="false"
                android:layout_marginEnd="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_pen"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                android:backgroundTint="@color/black"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonEraser"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:textAllCaps="false"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_eraser"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                android:backgroundTint="#000000"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonHand"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:textAllCaps="false"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_hand"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                android:backgroundTint="#000000"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonClear"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:textAllCaps="false"
                android:layout_marginStart="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_clear"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                android:backgroundTint="#000000"
                app:cornerRadius="24dp" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>