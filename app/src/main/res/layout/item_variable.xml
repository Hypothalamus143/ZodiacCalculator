<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header with name and type -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/editVariableName"
                android:layout_width="100dp"
                android:layout_height="48dp"
                android:text="x"
                android:textStyle="bold"
                android:textAlignment="center"
                android:background="@android:drawable/editbox_background"
                android:inputType="text"
                android:padding="8dp"
                android:layout_marginEnd="8dp" />

            <Spinner
                android:id="@+id/spinnerVariableType"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/buttonDeleteVariable"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:contentDescription="Delete Variable" />
        </LinearLayout>

        <!-- For CONSTANT type - value input -->
        <LinearLayout
            android:id="@+id/layoutConstantValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Value: "
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/seekBarVariable"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="32dp"
                android:max="100" />

            <EditText
                android:id="@+id/editTextVariableValue"
                android:layout_width="70dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:inputType="numberDecimal"
                android:textAlignment="center"
                android:background="@android:drawable/editbox_background"
                android:padding="8dp"
                android:hint="name" />
        </LinearLayout>

        <!-- For COMPUTED type - expression input -->
        <LinearLayout
            android:id="@+id/layoutComputedExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/editTextExpression"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Expression (e.g., x + y, x^2 + y)"
                android:inputType="text"
                android:background="@android:drawable/editbox_background"
                android:padding="12dp" />

            <TextView
                android:id="@+id/textComputedResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Result: "
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:padding="4dp" />

            <TextView
                android:id="@+id/textExpressionPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#999999"
                android:padding="4dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>